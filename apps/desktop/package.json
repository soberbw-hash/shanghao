{
  "name": "shanghao-desktop",
  "version": "0.1.50",
  "private": true,
  "description": "ShangHao desktop voice app for private friends group chat",
  "author": "Sober",
  "main": "dist-electron/main/index.cjs",
  "scripts": {
    "dev": "concurrently -k \"corepack pnpm dev:main\" \"corepack pnpm dev:renderer\" \"corepack pnpm dev:electron\"",
    "dev:main": "tsup --config tsup.config.ts --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 file:dist-electron/main/index.cjs && electron .",
    "build": "corepack pnpm build:main && corepack pnpm build:renderer",
    "build:main": "tsup --config tsup.config.ts",
    "build:renderer": "vite build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "tsc --project tsconfig.json --noEmit",
    "test:smoke": "node --import tsx --test tests/*.test.ts",
    "clean": "node ../../scripts/clean.mjs",
    "dist": "corepack pnpm build && node ../../scripts/run-electron-builder.mjs --config electron-builder.yml",
    "dist:win": "corepack pnpm build && node ../../scripts/run-electron-builder.mjs --config electron-builder.yml --win nsis",
    "dist:mac": "corepack pnpm build && node ../../scripts/run-electron-builder.mjs --config electron-builder.yml --mac dmg",
    "dist:mac:x64": "corepack pnpm build && node ../../scripts/run-electron-builder.mjs --config electron-builder.yml --mac dmg zip --x64",
    "dist:mac:arm64": "corepack pnpm build && node ../../scripts/run-electron-builder.mjs --config electron-builder.yml --mac dmg zip --arm64"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@private-voice/recording": "workspace:*",
    "@private-voice/shared": "workspace:*",
    "@private-voice/signaling": "workspace:*",
    "@private-voice/ui": "workspace:*",
    "@private-voice/webrtc": "workspace:*",
    "@shiguredo/rnnoise-wasm": "2025.1.5",
    "electron-updater": "6.8.9",
    "ffmpeg-static": "^5.2.0",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "lucide-react": "^0.511.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "semver": "^7.7.4",
    "stun": "^2.1.0",
    "uiohook-napi": "1.5.5",
    "ws": "^8.18.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.3",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wait-on": "^8.0.3"
  }
}
