{
  "name": "shanghao-workspace",
  "version": "0.1.32",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "corepack pnpm --dir apps/desktop dev",
    "build": "corepack pnpm -r --filter @private-voice/shared --filter @private-voice/ui --filter @private-voice/signaling --filter @private-voice/webrtc --filter @private-voice/recording --filter shanghao-desktop run build",
    "typecheck": "corepack pnpm -r --filter @private-voice/shared --filter @private-voice/ui --filter @private-voice/signaling --filter @private-voice/webrtc --filter @private-voice/recording --filter shanghao-desktop run typecheck",
    "lint": "corepack pnpm -r --filter @private-voice/shared --filter @private-voice/ui --filter @private-voice/signaling --filter @private-voice/webrtc --filter @private-voice/recording --filter shanghao-desktop run lint",
    "dist": "corepack pnpm --filter shanghao-desktop dist",
    "dist:win": "corepack pnpm --filter shanghao-desktop dist:win",
    "dist:mac": "corepack pnpm --filter shanghao-desktop dist:mac",
    "dist:mac:x64": "corepack pnpm --filter shanghao-desktop dist:mac:x64",
    "dist:mac:arm64": "corepack pnpm --filter shanghao-desktop dist:mac:arm64",
    "clean": "node scripts/clean.mjs",
    "release": "corepack pnpm typecheck && corepack pnpm --dir apps/desktop test:smoke && corepack pnpm dist",
    "relay": "corepack pnpm relay:start",
    "relay:dev": "corepack pnpm relay:build && node --watch scripts/start-relay.mjs",
    "relay:build": "corepack pnpm --filter @private-voice/shared build && corepack pnpm --filter @private-voice/signaling build",
    "relay:start": "corepack pnpm relay:build && node scripts/start-relay.mjs",
    "relay:health": "node -e \"fetch('http://127.0.0.1:43821/health').then(r=>r.text()).then(console.log)\"",
    "test:three-peer-audio": "corepack pnpm relay:build && node scripts/verify-three-peer-audio.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "electron",
      "electron-winstaller",
      "esbuild",
      "ffmpeg-static"
    ]
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
