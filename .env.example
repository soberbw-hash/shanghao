PORT=43821
ROOM_NAME=ShangHao
MAX_ROOM_MEMBERS=5
MAX_CONNECTIONS=100

# Optional but strongly recommended for friends on different carriers/NATs.
# Run scripts/install-turn.sh on the server, then keep these values private.
# TURN_URLS=turn:your.public.ip:3478?transport=udp,turn:your.public.ip:3478?transport=tcp
# TURN_SHARED_SECRET=replace-with-a-long-random-secret
# TURN_CREDENTIAL_TTL_SECONDS=86400

# Persist the latest 100 normal chat messages across relay restarts.
CHAT_HISTORY_FILE=./data/chat-history.json

# Require clients to present this token when joining a public relay.
# Generate a long random value and keep it private.
# RELAY_ACCESS_TOKEN=replace-with-a-long-random-token
